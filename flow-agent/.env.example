# Flow Agent Configuration Template
# Copy this file to '.env' and modify the values as needed.

# ─── WebSocket & Callback Server (Python agent <-> Chrome Extension) ───
# WebSocket port for Extension connection (Default: 9227)
WS_PORT=9227

# HTTP Callback port for Extension responses (Default: 8100)
HTTP_PORT=8100

# ─── Custom FastAPI API Server (External requests, port 8000) ───
# API server host address (Default: 127.0.0.1)
API_HOST=127.0.0.1

# API server port (Default: 8000)
API_PORT=8000

# Enable self-signed SSL certificate for HTTPS (true/false)
API_SSL=false

# Optional paths to your own SSL certificate and key files
# API_SSL_CERTFILE=
# API_SSL_KEYFILE=

# ─── OpenAI-Compatible Server Settings (Port 8001) ───
# OpenAI API server host address (Default: 127.0.0.1)
OPENAI_API_HOST=127.0.0.1

# OpenAI API server port (Default: 8001)
OPENAI_API_PORT=8001

# API Key required by clients to call this server (Leave empty to disable authentication)
SERVER_API_KEY=

# ─── Google Flow Settings ───
# Google Flow Default Project ID
DEFAULT_PROJECT=0143adf4-5864-4cb4-abb5-fe4254ad0dc7

# Image generation model (NARWHAL / GEM_PIX_2 / IMAGEN_4)
IMAGE_MODEL=NARWHAL

# ─── Polling & Timeouts ───
# Seconds to wait between polling Google Flow for generation status
POLL_INTERVAL=10

# Max seconds to wait for a video generation before timing out
POLL_TIMEOUT=420

# ─── Persistent media storage (optional) ───
# All optional — if unset, media is served from local disk via /download
# (ephemeral on HF) and history is kept in output/history.json.

# Public base for local /download URLs when R2 is not used
# PUBLIC_BASE_URL=https://flow1254-flow-backend-api.hf.space

# Cloudflare R2 via the upload Worker (see Browser-Agent infra). When all three
# are set, generated media is uploaded to R2 and served from the r2.dev URL.
# R2_UPLOAD_URL=https://flow-media.<subdomain>.workers.dev
# R2_UPLOAD_SECRET=
# R2_PUBLIC_BASE=https://pub-xxxxxxxx.r2.dev

# Neon Postgres for gallery/history metadata (table: media). Reuses the same DB
# as the browser-agent profilesync. When set, /v1/history reads from Postgres.
# DATABASE_URL=postgresql://user:pass@host.region.aws.neon.tech/db?sslmode=require
