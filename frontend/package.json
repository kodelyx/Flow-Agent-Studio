{
  "name": "frontend",
  "type": "module",
  "scripts": {
    "dev": "esbuild src/client.ts --bundle --outfile=public/app.js --watch=forever & tsx watch src/local.tsx",
    "build": "tsc && npm run build:client",
    "build:client": "esbuild src/client.ts --bundle --minify --outfile=public/app.js",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.5",
    "hono": "^4.12.26",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "esbuild": "^0.20.1",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3"
  }
}
