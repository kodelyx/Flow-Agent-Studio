# profilesync configuration
#
# DATABASE_URL — Neon Postgres connection string used to backup/restore the
# Chrome user-data profile (cookies/logins) across HF Space restarts.
# Copy this file to ".env" and fill in the real value. The .env file is
# gitignored and must NEVER be committed.
#
# On Hugging Face the same value must also be set as a Space secret:
#   Space → Settings → Variables and secrets → New secret → DATABASE_URL
#
DATABASE_URL=postgresql://USER:PASSWORD@HOST.region.aws.neon.tech/DBNAME?sslmode=require
